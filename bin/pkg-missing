#!/bin/bash

# Like omarchy-pkg-missing, but a name may also be a package group.
# Returns true (exit 0) if any of the named packages/groups are missing.
#
# Group membership is checked against the local db (`pacman -Qg`, fast) rather
# than the sync db (`pacman -Sgq`, ~8x slower). A group therefore counts as
# installed once it has installed members; a member newly added to the group
# upstream won't be noticed until the group is queried with a sync.

for pkg in "$@"; do
  # Installed as a package, or an installed package group.
  pacman -Q "$pkg" &>/dev/null && continue
  pacman -Qg "$pkg" &>/dev/null && continue

  # Neither an installed package nor an installed group.
  exit 0
done

exit 1
